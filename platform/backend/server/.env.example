# =================================================================
# Viet-Contech Design Platform — Master API Server
# Sao chep file nay sang `.env` va dien lai gia tri thuc
# =================================================================

# --- HTTP server ---
PORT=8787
NODE_ENV=development

# --- CORS (csv list, dau "*" = allow all dev only) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://viet-contech.com

# --- JWT (32+ ky tu, doi cho production) ---
JWT_SECRET=change-me-to-a-32+chars-random-secret-please
JWT_ISSUER=viet-contech.com
JWT_AUDIENCE=vct-design-platform
JWT_TTL_SECONDS=604800

# --- Cookie ---
COOKIE_NAME=vct_session
COOKIE_SECURE=false
COOKIE_DOMAIN=

# --- Database (better-sqlite3 file path; tuong doi se resolve ve backend root) ---
VCT_DB_PATH=data/vct.db

# --- SMTP Gmail (dung App Password, KHONG password thuong) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youraddress@gmail.com
SMTP_PASS=app-password-16-chars
SMTP_FROM="Viet-Contech <youraddress@gmail.com>"

# --- OTP behaviour ---
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# --- Rate-limit (req / minute / key) ---
RATE_LIMIT_USER_RPM=100
RATE_LIMIT_IP_RPM=1000

# --- Optional providers ---
# Khi vang: hieu la dev mode, agent runner se dung mock provider
ZENI_L3_API_KEY=
ZENI_L3_BASE_URL=https://api.zeni.cloud/v1

# --- Agent runner mode (mock | real) ---
# mock: tra response gia realistic, latency 50-300ms (default)
# real: goi Zeni Cloud Lop 03 router (yeu cau ZENI_ROUTER_URL + ZENI_API_KEY)
PROVIDER_MODE=mock
ZENI_ROUTER_URL=
ZENI_WORKSPACE=
ZENI_API_KEY=

# --- Public base url (dung khi build link deliverable) ---
PUBLIC_BASE_URL=http://localhost:8787

# --- Build metadata (auto-set by CI/CD; ignore for local dev) ---
GIT_COMMIT=
GIT_BRANCH=
