{
  "name": "viet-contech-backend",
  "version": "0.1.0",
  "description": "Viet-Contech backend (Hono + Zeni Cloud) — stateless API for landing page, AI interior render, phong thuy, contacts, dashboard.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests yet — add vitest later\" && exit 0",
    "docker:build": "docker build -t viet-contech-backend .",
    "docker:run": "docker run --rm -p 8787:8787 --env-file .env -v vct_data:/app/data viet-contech-backend"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@types/nodemailer": "^8.0.0",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "nodemailer": "^8.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
