{
  "category": "concrete",
  "standard": "TCVN 5574:2018",
  "title_vi": "Ket cau be tong va be tong cot thep - Tieu chuan thiet ke",
  "title_en": "Concrete and reinforced concrete structures - Design code",
  "version": "2018",
  "rules": [
    {
      "code": "C001",
      "version": "1.0",
      "statement_vi": "Mac be tong toi thieu cho nha o dan dung",
      "statement_en": "Minimum concrete grade for residential buildings",
      "formula": "concrete_grade >= 'B20'",
      "inputs": ["concrete_grade"],
      "expected": "B20",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 18, "section": "5.1.2" }
    },
    {
      "code": "C002",
      "version": "1.0",
      "statement_vi": "Cuong do chiu nen tinh toan Rb cho B20",
      "statement_en": "Design compressive strength Rb for B20",
      "formula": "if grade=B20 then Rb=11.5 MPa",
      "inputs": ["concrete_grade"],
      "expected": { "B20": 11.5, "B25": 14.5, "B30": 17, "B40": 22 },
      "severity": "info",
      "references": { "tcvn": "TCVN 5574:2018", "page": 23, "section": "Table 7" }
    },
    {
      "code": "C003",
      "version": "1.0",
      "statement_vi": "Lop bao ve cot thep dam/cot trong nha",
      "statement_en": "Concrete cover for beams/columns indoor",
      "formula": "cover_indoor_beam_column >= 20",
      "inputs": ["cover_mm", "element_type", "exposure"],
      "expected": 20,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 71, "section": "10.3.2" }
    },
    {
      "code": "C004",
      "version": "1.0",
      "statement_vi": "Lop bao ve cot thep dam/cot ngoai troi",
      "statement_en": "Concrete cover for beams/columns outdoor",
      "formula": "cover_outdoor_beam_column >= 25",
      "inputs": ["cover_mm", "element_type", "exposure"],
      "expected": 25,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 71, "section": "10.3.2" }
    },
    {
      "code": "C005",
      "version": "1.0",
      "statement_vi": "Lop bao ve cot thep san",
      "statement_en": "Concrete cover for slabs",
      "formula": "cover_slab >= 15",
      "inputs": ["cover_mm", "element_type"],
      "expected": 15,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 71, "section": "10.3.2" }
    },
    {
      "code": "C006",
      "version": "1.0",
      "statement_vi": "Duong kinh thep doc cot toi thieu",
      "statement_en": "Minimum longitudinal rebar diameter for columns",
      "formula": "phi_long_column >= 12",
      "inputs": ["phi_long_column_mm"],
      "expected": 12,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 95, "section": "11.2.1" }
    },
    {
      "code": "C007",
      "version": "1.0",
      "statement_vi": "Duong kinh thep doc dam toi thieu",
      "statement_en": "Minimum longitudinal rebar diameter for beams",
      "formula": "phi_long_beam >= 10",
      "inputs": ["phi_long_beam_mm"],
      "expected": 10,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 90, "section": "11.1.5" }
    },
    {
      "code": "C008",
      "version": "1.0",
      "statement_vi": "Duong kinh cot dai toi thieu",
      "statement_en": "Minimum stirrup diameter",
      "formula": "phi_stirrup >= 6",
      "inputs": ["phi_stirrup_mm"],
      "expected": 6,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 92, "section": "11.1.7" }
    },
    {
      "code": "C009",
      "version": "1.0",
      "statement_vi": "Ty le thep cot toi thieu mu_min",
      "statement_en": "Minimum reinforcement ratio for column",
      "formula": "mu_column >= 0.4",
      "inputs": ["mu_column_pct"],
      "expected": 0.4,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 96, "section": "11.2.3" }
    },
    {
      "code": "C010",
      "version": "1.0",
      "statement_vi": "Ty le thep cot toi da mu_max",
      "statement_en": "Maximum reinforcement ratio for column",
      "formula": "mu_column <= 6",
      "inputs": ["mu_column_pct"],
      "expected": 6,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 96, "section": "11.2.3" }
    },
    {
      "code": "C011",
      "version": "1.0",
      "statement_vi": "Khoang cach cot dai cot",
      "statement_en": "Stirrup spacing in columns",
      "formula": "spacing_stirrup_column <= min(15*phi_long, 500)",
      "inputs": ["spacing_stirrup_mm", "phi_long_column_mm"],
      "expected": "min(15*phi_long, 500)",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 97, "section": "11.2.4" }
    },
    {
      "code": "C012",
      "version": "1.0",
      "statement_vi": "Do vong cho phep dam (tai song)",
      "statement_en": "Allowable beam deflection (live load)",
      "formula": "deflection_live <= L/250",
      "inputs": ["deflection_live_mm", "span_mm"],
      "expected": "L/250",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 110, "section": "12.2.1" }
    },
    {
      "code": "C013",
      "version": "1.0",
      "statement_vi": "Do vong cho phep dam (toan bo)",
      "statement_en": "Allowable beam deflection (total)",
      "formula": "deflection_total <= L/150",
      "inputs": ["deflection_total_mm", "span_mm"],
      "expected": "L/150",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 110, "section": "12.2.1" }
    },
    {
      "code": "C014",
      "version": "1.0",
      "statement_vi": "Nhip dam BTCT thuc te khong can du ung luc",
      "statement_en": "Practical RC beam span without prestressing",
      "formula": "span_beam <= 8000",
      "inputs": ["span_beam_mm"],
      "expected": 8000,
      "severity": "warn",
      "references": { "tcvn": "TCVN 5574:2018", "page": 80, "section": "11.1.1" }
    },
    {
      "code": "C015",
      "version": "1.0",
      "statement_vi": "Tiet dien cot toi thieu cho nha 3 tang",
      "statement_en": "Minimum column section for 3-storey building",
      "formula": "column_b * column_h >= 200*200",
      "inputs": ["column_b_mm", "column_h_mm", "num_floors"],
      "expected": "200x200",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 96, "section": "11.2.2" }
    },
    {
      "code": "C016",
      "version": "1.0",
      "statement_vi": "Tiet dien cot toi thieu cho nha 4-5 tang",
      "statement_en": "Minimum column section for 4-5 storey building",
      "formula": "if num_floors>=4 then column_b*column_h >= 220*220",
      "inputs": ["column_b_mm", "column_h_mm", "num_floors"],
      "expected": "220x220",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 96, "section": "11.2.2" }
    },
    {
      "code": "C017",
      "version": "1.0",
      "statement_vi": "Tiet dien cot toi thieu cho nha >=6 tang",
      "statement_en": "Minimum column section for >=6 storey building",
      "formula": "if num_floors>=6 then column_b*column_h >= 250*250",
      "inputs": ["column_b_mm", "column_h_mm", "num_floors"],
      "expected": "250x250",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 96, "section": "11.2.2" }
    },
    {
      "code": "C018",
      "version": "1.0",
      "statement_vi": "Be day san toi thieu BTCT",
      "statement_en": "Minimum slab thickness RC",
      "formula": "slab_thickness >= 80",
      "inputs": ["slab_thickness_mm"],
      "expected": 80,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 105, "section": "11.3.1" }
    },
    {
      "code": "C019",
      "version": "1.0",
      "statement_vi": "Be day san san nha o thuong",
      "statement_en": "Recommended slab thickness for residential",
      "formula": "slab_thickness >= 100",
      "inputs": ["slab_thickness_mm"],
      "expected": 100,
      "severity": "warn",
      "references": { "tcvn": "TCVN 5574:2018", "page": 105, "section": "11.3.1" }
    },
    {
      "code": "C020",
      "version": "1.0",
      "statement_vi": "Khoang cach thep san toi da",
      "statement_en": "Maximum rebar spacing in slab",
      "formula": "rebar_spacing_slab <= 200",
      "inputs": ["rebar_spacing_slab_mm"],
      "expected": 200,
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 106, "section": "11.3.3" }
    },
    {
      "code": "C021",
      "version": "1.0",
      "statement_vi": "Mac be tong cau thang",
      "statement_en": "Concrete grade for staircase",
      "formula": "grade_staircase >= 'B20'",
      "inputs": ["concrete_grade_staircase"],
      "expected": "B20",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 18, "section": "5.1.2" }
    },
    {
      "code": "C022",
      "version": "1.0",
      "statement_vi": "Mo dun dan hoi be tong B20 Eb",
      "statement_en": "Modulus of elasticity for B20 Eb",
      "formula": "if grade=B20 then Eb=27000 MPa",
      "inputs": ["concrete_grade"],
      "expected": { "B20": 27000, "B25": 30000, "B30": 32500, "B40": 36000 },
      "severity": "info",
      "references": { "tcvn": "TCVN 5574:2018", "page": 24, "section": "Table 8" }
    },
    {
      "code": "C023",
      "version": "1.0",
      "statement_vi": "Cuong do chiu keo thep CB400-V Rs",
      "statement_en": "Design tensile strength of CB400-V steel",
      "formula": "Rs_CB400V = 350 MPa",
      "inputs": ["steel_grade"],
      "expected": { "CB300-V": 260, "CB400-V": 350, "CB500-V": 435 },
      "severity": "info",
      "references": { "tcvn": "TCVN 5574:2018", "page": 30, "section": "Table 13" }
    },
    {
      "code": "C024",
      "version": "1.0",
      "statement_vi": "Khoang cach cot dai dam vung sat goi tua",
      "statement_en": "Stirrup spacing in beam near support",
      "formula": "spacing_stirrup_support <= h/2 and <= 150mm",
      "inputs": ["spacing_stirrup_mm", "beam_h_mm"],
      "expected": "min(h/2, 150)",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 91, "section": "11.1.7" }
    },
    {
