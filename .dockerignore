# =====================================================
# .dockerignore — giu image gon va khong leak secret
# =====================================================

# Deps — Docker se npm ci lai trong builder
node_modules
.pnp
.pnp.js

# Build artifact local — Docker se build tu source
dist
build
*.tsbuildinfo

# Secrets — TUYET DOI KHONG copy vao image
.env
.env.*
!.env.example

# Git
.git
.gitignore
.gitattributes

# Database files local (SQLite) — volume mount khi runtime, khong nhung trong image
data
db/*.db
db/*.db-journal
db/*.sqlite
db/*.sqlite3
*.db
*.sqlite
*.sqlite3

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / IDE
.DS_Store
Thumbs.db
.vscode
.idea
*.swp

# Test / Coverage
coverage
.nyc_output
test
__tests__
*.test.ts
*.spec.ts

# Docs / config khong can o runtime
README.md
*.md
LICENSE

# Docker self
Dockerfile
.dockerignore
docker-compose*.yml

# CI
.github
