      "references": { "tcvn": "TCVN 5574:2018", "page": 75, "section": "10.4.1" }
    },
    {
      "code": "C026",
      "version": "1.0",
      "statement_vi": "Khoang cach giua cac thanh thep doc dam",
      "statement_en": "Spacing between longitudinal beam rebars",
      "formula": "spacing_long_beam >= max(phi, 25mm)",
      "inputs": ["spacing_long_beam_mm", "phi_long_beam_mm"],
      "expected": "max(phi, 25)",
      "severity": "error",
      "references": { "tcvn": "TCVN 5574:2018", "page": 90, "section": "11.1.5" }
    },
    {
      "code": "C027",
      "version": "1.0",
      "statement_vi": "Cuong do chiu keo tinh toan be tong B20 Rbt",
      "statement_en": "Design tensile strength of B20 concrete Rbt",
      "formula": "Rbt_B20 = 0.9 MPa",
      "inputs": ["concrete_grade"],
      "expected": { "B20": 0.9, "B25": 1.05, "B30": 1.15, "B40": 1.4 },
      "severity": "info",
      "references": { "tcvn": "TCVN 5574:2018", "page": 23, "section": "Table 7" }
