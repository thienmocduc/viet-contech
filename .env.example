# =====================================================
# Viet-Contech Backend — Environment Variables
# Copy file nay thanh `.env` va dien gia tri that
# KHONG commit `.env` len git
# =====================================================

# --- Server ---
NODE_ENV=development
PORT=8787
FRONTEND_URL=http://localhost:8765

# --- Provider Mode (mock cho dev, real cho production) ---
PROVIDER_MODE=mock

# --- JWT / Session cookie ---
# Sinh key 32 bytes: openssl rand -hex 32
JWT_SECRET=replace-with-32-bytes-hex-secret-min-32chars
SESSION_COOKIE_NAME=vct_sess
SESSION_TTL_SECONDS=604800

# --- CORS allowed origins (comma-separated) ---
CORS_ORIGINS=https://vietcontech.com,http://localhost:8765

# --- Database (better-sqlite3 file path; swap sang Postgres tren prod) ---
DB_PATH=./data/viet_contech.db

# --- Zeni Cloud — Lop 02 Data Lake (Postgres REST) ---
ZENI_L2_BASE_URL=https://l2.viet_contech.zenicloud.io
ZENI_L2_API_KEY=replace-with-l2-api-key
ZENI_L2_SCHEMA=viet_contech

# --- Zeni Cloud — Lop 03 AI Engine ---
ZENI_L3_BASE_URL=https://l3.viet_contech.zenicloud.io
ZENI_L3_API_KEY=replace-with-l3-api-key
ZENI_L3_MODEL=sd-lora-interior

# --- Zeni Cloud — Lop 03 Object Storage (cho upload anh AI) ---
ZENI_L3_STORAGE_BUCKET=viet-contech-uploads
ZENI_L3_STORAGE_BASE_URL=https://storage.zenicloud.io

# --- Zeni Cloud — Lop 04 Automation Event Bus ---
ZENI_L4_BASE_URL=https://l4.viet_contech.zenicloud.io
ZENI_L4_API_KEY=replace-with-l4-api-key

# Connector: Zalo Official Account
ZALO_OA_ID=replace-with-zalo-oa-id
ZALO_OA_ACCESS_TOKEN=replace-with-zalo-token

# Connector: VNPay
VNPAY_TMN_CODE=replace-with-tmn-code
VNPAY_HASH_SECRET=replace-with-vnpay-hash-secret
VNPAY_ENDPOINT=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=https://vietcontech.com/membership/callback

# Connector: SendGrid email
SENDGRID_API_KEY=replace-with-sendgrid-key
SENDGRID_FROM_EMAIL=no-reply@vietcontech.com
SALES_NOTIFY_EMAIL=sales@vietcontech.com
DESIGNER_NOTIFY_EMAIL=designer@vietcontech.com

# --- Zeni Cloud — Lop 05 Identity SSO (OIDC / OAuth2) ---
ZENI_L5_BASE_URL=https://l5.viet_contech.zenicloud.io
ZENI_L5_CLIENT_ID=replace-with-client-id
ZENI_L5_CLIENT_SECRET=replace-with-client-secret
ZENI_L5_REDIRECT_URI=https://api.vietcontech.com/api/auth/sso/callback
ZENI_L5_AUTHORIZE_URL=https://l5.viet_contech.zenicloud.io/oauth/authorize
ZENI_L5_TOKEN_URL=https://l5.viet_contech.zenicloud.io/oauth/token
ZENI_L5_USERINFO_URL=https://l5.viet_contech.zenicloud.io/oauth/userinfo

# Google / Zalo OAuth (cho real mode)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-secret
ZALO_APP_ID=replace-with-zalo-app-id
ZALO_APP_SECRET=replace-with-zalo-secret
