      "inputs": ["master_bedroom_m2"],
      "expected": 12,
      "severity": "error",
      "references": { "tcvn": "TCVN 4451:2012", "page": 9, "section": "5.3.1" }
    },
    {
      "code": "H005",
      "version": "1.0",
      "statement_vi": "Dien tich phong ngu phu >=9m2",
      "statement_en": "Secondary bedroom area >=9m2",
      "formula": "secondary_bedroom >= 9",
      "inputs": ["secondary_bedroom_m2"],
      "expected": 9,
      "severity": "error",
      "references": { "tcvn": "TCVN 4451:2012", "page": 9, "section": "5.3.1" }
    },
    {
      "code": "H006",
      "version": "1.0",
      "statement_vi": "Dien tich bep >=6m2",
