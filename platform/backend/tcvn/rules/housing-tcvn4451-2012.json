{
  "category": "housing",
  "standard": "TCVN 4451:2012",
  "title_vi": "Nha o - Nguyen tac co ban de thiet ke",
  "title_en": "Residential houses - Basic principles for design",
  "version": "2012",
  "rules": [
    {
      "code": "H001",
      "version": "1.0",
      "statement_vi": "Chieu cao tran phong o >=2.7m",
      "statement_en": "Living room ceiling height >=2.7m",
      "formula": "ceiling_main_room >= 2.7",
      "inputs": ["ceiling_main_room_m"],
      "expected": 2.7,
      "severity": "error",
      "references": { "tcvn": "TCVN 4451:2012", "page": 8, "section": "5.2.1" }
    },
    {
      "code": "H002",
      "version": "1.0",
      "statement_vi": "Chieu cao tran phong phu (WC, kho, bep) >=2.4m",
      "statement_en": "Auxiliary room ceiling height >=2.4m",
      "formula": "ceiling_aux_room >= 2.4",
      "inputs": ["ceiling_aux_room_m"],
      "expected": 2.4,
      "severity": "error",
      "references": { "tcvn": "TCVN 4451:2012", "page": 8, "section": "5.2.2" }
    },
    {
      "code": "H003",
      "version": "1.0",
      "statement_vi": "Dien tich cua so >= 1/8 dien tich san",
      "statement_en": "Window area >= 1/8 floor area",
      "formula": "window_area >= floor_area/8",
      "inputs": ["window_area_m2", "floor_area_m2"],
      "expected": "floor_area/8",
      "severity": "error",
      "references": { "tcvn": "TCVN 4451:2012", "page": 11, "section": "5.4.1" }
    },
    {
      "code": "H004",
      "version": "1.0",
      "statement_vi": "Dien tich phong ngu chinh >=12m2",
      "statement_en": "Master bedroom area >=12m2",
